# =============================================================================
# Pipe-LeadFinder — env layout aligned with ClickCampaigns-ai
# Copy to .env and fill in values. Never commit .env
# =============================================================================

# Session / NextAuth (generate: openssl rand -base64 32)
SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_URL=http://localhost:3000

# Neon → DigitalOcean one-time copy (see scripts/migrate-postgres-to-do.sh; needs SOURCE_DATABASE_URL from Neon console)

# DigitalOcean Managed PostgreSQL
DATABASE_URL=postgresql://doadmin:REPLACE_PASSWORD@REPLACE_HOST.db.ondigitalocean.com:25061/REPLACE_DATABASE?sslmode=require
PGDATABASE=REPLACE_DATABASE
PGHOST=REPLACE_HOST.db.ondigitalocean.com
PGPORT=25061
PGUSER=doadmin
PGPASSWORD=REPLACE_PASSWORD

# Replicate (optional)
REPLICATE_API_KEY=r8_REPLACE_ME

# Keycloak / OIDC — used by both client (keycloak-js) and server (jose JWKS)
# NEXT_PUBLIC_ prefix exposes these to the browser (required for keycloak-js)
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.groovetech.io/auth
NEXT_PUBLIC_KEYCLOAK_REALM=gd-apis-live
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=app-pipefinder
# Required Keycloak realm role (users without this role are blocked)
# NEXT_PUBLIC_KEYCLOAK_REQUIRED_ROLE=App_pipefinder

# App hosting
BASE_URL=http://localhost:3000
NODE_ENV=development
DEV_AUTO_LOGIN=true
NEXT_PUBLIC_DEV_AUTO_LOGIN=true
PORT=3000

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# OpenAI
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Pexels
PEXELS_API_KEY=REPLACE_PEXELS_KEY

# Fal.ai (optional)
FAL_AI_API_KEY=REPLACE_UUID:REPLACE_SECRET

# Admin allowlists
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=@example.com

# DigitalOcean Spaces (S3-compatible object storage)
DO_SPACES_KEY=REPLACE_DO_SPACES_KEY
DO_SPACES_SECRET=REPLACE_DO_SPACES_SECRET
DO_SPACES_BUCKET=scaleplus
DO_SPACES_REGION=nyc3
MAX_AI_TOKENS=60000

# Google Gemini / Generative AI
GOOGLE_API_KEY=AIzaSy_REPLACE_ME
GEMINI_API_KEY=AIzaSy_REPLACE_ME
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy_REPLACE_ME

# Firecrawl
FIRECRAWL_API_KEY=fc-REPLACE_ME

# ScaleCredits microservice
MICRO_SERVICE_BASE=http://localhost:3002/api
SCALECREDITS_URL=https://credits.scaleplus.gg
NEXT_PUBLIC_SCALECREDITS_URL=https://credits.scaleplus.gg

# Apify
APIFY_API_KEY=apify_api_REPLACE_ME

# Apify Actor IDs (configure per search type)
APIFY_ACTOR_PEOPLE=harvestapi/linkedin-profile-search
APIFY_ACTOR_LOCAL=agents/google-maps-search
APIFY_ACTOR_COMPANY=apimaestro/linkedin-companies-search-scraper
APIFY_ACTOR_DOMAIN=george.the.developer/company-enrichment-api
APIFY_ACTOR_INFLUENCER=alizarin_refrigerator-owner/influencer-discovery---find-influencers-across-social-platforms
APIFY_ACTOR_ENRICH_EMAIL=code_crafter/personal-email-finder
APIFY_ACTOR_ENRICH_PHONE=code_crafter/mobile-finder

# =============================================================================
# Pipe-LeadFinder — env layout aligned with ClickCampaigns-ai
# Copy to .env and fill in values. Never commit .env
# =============================================================================

# Session / NextAuth (generate: openssl rand -base64 32)
SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_URL=http://localhost:3000

# Neon database (optional — uncomment if using Neon instead of DO)
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require

# DigitalOcean Managed PostgreSQL
DATABASE_URL=postgresql://doadmin:REPLACE_PASSWORD@REPLACE_HOST.db.ondigitalocean.com:25061/REPLACE_DATABASE?sslmode=require
PGDATABASE=REPLACE_DATABASE
PGHOST=REPLACE_HOST.db.ondigitalocean.com
PGPORT=25061
PGUSER=doadmin
PGPASSWORD=REPLACE_PASSWORD

# Replicate (optional)
REPLICATE_API_KEY=r8_REPLACE_ME

# Keycloak / OIDC (names mirror ClickCampaigns-ai)
VITE_KEYCLOAK_BASE_URL=https://auth.example.com/auth
VITE_KEYCLOAK_REALM=REPLACE_REALM
VITE_KEYCLOAK_CLIENT_ID=REPLACE_CLIENT_ID

# App hosting
BASE_URL=http://localhost:3000
NODE_ENV=development
DEV_AUTO_LOGIN=true
PORT=3000

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# OpenAI
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Pexels
PEXELS_API_KEY=REPLACE_PEXELS_KEY

# Fal.ai (optional)
FAL_AI_API_KEY=REPLACE_UUID:REPLACE_SECRET

# Admin allowlists
ADMIN_EMAILS=admin@example.com
ADMIN_DOMAINS=@example.com

# Google Cloud Storage
GCS_BUCKET_NAME=pipe-leadfinder
GCS_PROJECT_ID=REPLACE_GCP_PROJECT_ID
GOOGLE_APPLICATION_CREDENTIALS=./server/config/credentials/REPLACE_SERVICE_ACCOUNT.json
STORAGE_PROVIDER=gcs
MAX_AI_TOKENS=60000

# Google Gemini / Generative AI
GOOGLE_API_KEY=AIzaSy_REPLACE_ME
GEMINI_API_KEY=AIzaSy_REPLACE_ME
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy_REPLACE_ME

# Firecrawl
FIRECRAWL_API_KEY=fc-REPLACE_ME

# Apify
APIFY_API_KEY=apify_api_REPLACE_ME

# Apify Actor IDs (configure per search type)
APIFY_ACTOR_PEOPLE=harvestapi/linkedin-profile-search
APIFY_ACTOR_LOCAL=agents/google-maps-search
APIFY_ACTOR_COMPANY=apimaestro/linkedin-companies-search-scraper
APIFY_ACTOR_DOMAIN=george.the.developer/company-enrichment-api
APIFY_ACTOR_INFLUENCER=alizarin_refrigerator-owner/influencer-discovery---find-influencers-across-social-platforms
APIFY_ACTOR_ENRICH_EMAIL=vDOgvZ1AZ05y7H7iD
APIFY_ACTOR_ENRICH_PHONE=vDOgvZ1AZ05y7H7iD
